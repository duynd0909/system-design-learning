# ─── API Connection ───────────────────────────────────────────────────────────
# Local dev: points to the NestJS API running on :3001
# Railway production: set to your API service public URL
NEXT_PUBLIC_API_URL="https://api.stackdify.space/api/v1"
NEXT_PUBLIC_APP_URL="https://stackdify.space"

# ─── Observability ────────────────────────────────────────────────────────────
# Client DSN is public by design. Server DSN can use the same Sentry project.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# ─── Next.js Server Port ──────────────────────────────────────────────────────
# Runtime port for `next start`; change this value to change the web process port.
# Dockerfile and Railway start command intentionally do not hardcode `-p`.
PORT=3000

# ─── Railway Production Checklist ─────────────────────────────────────────────
# Variables to set in Railway Dashboard → Web Service → Variables:
#
#   NEXT_PUBLIC_API_URL → https://api.stackdify.space/api/v1
#   NEXT_PUBLIC_APP_URL → https://stackdify.space
#   NEXT_PUBLIC_SENTRY_DSN / SENTRY_DSN → Sentry project DSNs
#   PORT                → 3000
#
# Next reads PORT at runtime, so Railway's PORT variable controls the container port sample.
