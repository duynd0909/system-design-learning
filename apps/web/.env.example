# ─── API Connection ───────────────────────────────────────────────────────────
# Local dev: points to the NestJS API running on :3001
# Railway production: set to your API service public URL
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ─── Railway Production Checklist ─────────────────────────────────────────────
# Variables to set in Railway Dashboard → Web Service → Variables:
#
#   NEXT_PUBLIC_API_URL → https://api.stackdify.space/api/v1
#
# Railway sets PORT automatically — do not add it manually.
