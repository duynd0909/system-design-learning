# ─── API Connection ───────────────────────────────────────────────────────────
# Local dev: points to the NestJS API running on :3001
# Railway production: set to your API service public URL
NEXT_PUBLIC_API_URL="https://api.stackdify.space/api/v1"

# ─── Next.js Server Port ──────────────────────────────────────────────────────
# Runtime port for `next start`; change this value to change the web process port.
# Dockerfile and Railway start command intentionally do not hardcode `-p`.
PORT=3000

# ─── Railway Production Checklist ─────────────────────────────────────────────
# Variables to set in Railway Dashboard → Web Service → Variables:
#
#   NEXT_PUBLIC_API_URL → https://api.stackdify.space/api/v1
#   PORT                → 3000
#
# Next reads PORT at runtime, so Railway's PORT variable controls the container port.
