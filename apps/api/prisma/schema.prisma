generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  displayName  String
  avatarUrl    String?
  password     String?  // null for OAuth-only users
  githubId     String?  @unique
  googleId     String?  @unique
  xp           Int      @default(0)
  level        Int      @default(1)
  streak       Int      @default(0)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions Submission[]

  @@map("users")
}

model ComponentType {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  description String
  iconUrl     String?
  category    String
  createdAt   DateTime @default(now())

  @@map("component_types")
}

model Problem {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  difficulty  Difficulty
  category    String
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  requirements Requirement[]
  submissions  Submission[]

  @@map("problems")
}

// Each problem has 2–4 requirements that unlock sequentially.
// Only NEW nodes/edges for this requirement are stored here;
// the service accumulates across requirements 1..N to build the full canvas.
model Requirement {
  id          String   @id @default(cuid())
  problemId   String
  order       Int      // 1-based; requirements unlock in ascending order
  title       String
  description String
  nodes       Json     // GraphNode[] — nodes introduced by this requirement
  edges       Json     // GraphEdge[] — edges for this requirement (may reference prior-req nodes)
  answer      Json     // { nodeId: componentTypeSlug } — blank nodes for THIS requirement only

  createdAt DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, order])
  @@index([problemId])
  @@map("requirements")
}

model Submission {
  id               String   @id @default(cuid())
  userId           String
  problemId        String
  requirementOrder Int?     // which requirement was submitted; null = legacy
  score            Int
  passed           Boolean
  xpEarned         Int
  timeTakenMs      Int
  slotAnswers      Json     // { nodeId: componentTypeSlug }
  slotResults      Json     // SlotResult[]
  createdAt        DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([problemId])
  @@index([userId, problemId])
  @@map("submissions")
}
