# ─── Database & Cache ─────────────────────────────────────────────────────────
# Local dev: start services with `docker-compose up -d`
# Railway production: injected automatically from PostgreSQL + Redis plugins
DATABASE_URL="postgresql://stackdify:stackdify@localhost:5432/stackdify_dev"
REDIS_URL="redis://localhost:6379"
DATABASE_POOL_MAX=10

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a production secret: openssl rand -base64 32
JWT_SECRET="dev-secret-min-32-chars-change-in-prod"
JWT_EXPIRES_IN="7d"

# ─── OAuth Providers ──────────────────────────────────────────────────────────
# GitHub OAuth App — https://github.com/settings/developers
#   Callback URL (local):  http://localhost:3001/api/v1/auth/github/callback
#   Callback URL (prod):   https://api.stackdify.space/api/v1/auth/github/callback
GITHUB_CLIENT_ID="your-github-oauth-app-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-app-client-secret"

# Google OAuth 2.0 — https://console.cloud.google.com → APIs & Services → Credentials
#   Redirect URI (local):  http://localhost:3001/api/v1/auth/google/callback
#   Redirect URI (prod):   https://api.stackdify.space/api/v1/auth/google/callback
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# ─── App ──────────────────────────────────────────────────────────────────────
# Public API origin used to build OAuth provider callback URLs.
API_PUBLIC_URL="http://localhost:3001"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"
# Railway sets PORT automatically — do not override in production
PORT=3001

# ─── Admin / Observability ────────────────────────────────────────────────────
# Comma-separated emails that can access /api/v1/admin/*.
ADMIN_EMAILS="admin@example.com"
# Optional Sentry DSN for backend exception tracking.
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"

# ─── AWS S3 (Phase 2 / AWS only — not needed for Railway) ─────────────────────
# AWS_S3_BUCKET="stackdify-assets-prod"
# AWS_REGION="ap-southeast-1"

# ─── Railway Production Variables ─────────────────────────────────────────────
# Set these in Railway Dashboard → API Service → Variables:
#
#   DATABASE_URL          auto-injected by Railway PostgreSQL plugin
#   REDIS_URL             auto-injected by Railway Redis plugin
#   DATABASE_POOL_MAX     10 (lower this if Railway Postgres connection limits require it)
#   JWT_SECRET            openssl rand -base64 32
#   JWT_EXPIRES_IN        7d
#   ADMIN_EMAILS          comma-separated admin emails
#   SENTRY_DSN            backend Sentry project DSN
#   SENTRY_TRACES_SAMPLE_RATE 0.1
#   GITHUB_CLIENT_ID      production OAuth App credentials
#   GITHUB_CLIENT_SECRET
#   GOOGLE_CLIENT_ID      production OAuth credentials
#   GOOGLE_CLIENT_SECRET
#   API_PUBLIC_URL        https://api.stackdify.space
#   CORS_ORIGIN           https://stackdify.space
#   NODE_ENV              production
